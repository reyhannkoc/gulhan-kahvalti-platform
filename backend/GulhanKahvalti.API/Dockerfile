# Build stage
FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /src

COPY ["GulhanKahvalti.API.csproj", "./"]
RUN dotnet restore "GulhanKahvalti.API.csproj"

COPY . .
RUN dotnet publish "GulhanKahvalti.API.csproj" -c Release -o /app/publish /p:UseAppHost=false

# Runtime stage
FROM mcr.microsoft.com/dotnet/aspnet:8.0 AS final
WORKDIR /app

COPY --from=build /app/publish .

ENV ASPNETCORE_URLS=http://+:10000
EXPOSE 10000

ENTRYPOINT ["dotnet", "GulhanKahvalti.API.dll"]
